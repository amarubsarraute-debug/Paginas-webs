# =====================================================================
#  Maggie's — Variables de entorno
# =====================================================================
#
# Copiá este archivo como ".env.local" y completá los valores.
#   En Windows (PowerShell):  Copy-Item .env.example .env.local
#   En Mac/Linux:             cp .env.example .env.local
#
# IMPORTANTE: las variables NEXT_PUBLIC_ quedan visibles en el navegador.
# NUNCA pongas claves secretas (service_role, access token de Mercado Pago,
# password admin) en variables NEXT_PUBLIC_.
#
# La web FUNCIONA SIN configurar nada: si no hay Supabase, usa el menú local
# (src/data/menu.json) y el checkout ofrece solo WhatsApp. A medida que
# completás credenciales, se activan las funciones reales.
# ---------------------------------------------------------------------

# --- App --------------------------------------------------------------
# URL pública del sitio (sin barra final). En local: http://localhost:8790
# En producción: https://tu-dominio.vercel.app  (necesaria para Mercado Pago).
NEXT_PUBLIC_APP_URL=http://localhost:8790

# Slug del negocio por defecto que se muestra en "/" (multi-negocio).
NEXT_PUBLIC_DEFAULT_BUSINESS_SLUG=maggies

# --- Supabase ---------------------------------------------------------
# Project URL y claves: Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role: acceso total, SOLO servidor. Nunca exponer ni commitear.
SUPABASE_SERVICE_ROLE_KEY=

# --- Mercado Pago (pago online opcional) ------------------------------
# Access Token de PRODUCCIÓN o TEST: Mercado Pago → Tus integraciones →
# Credenciales. SOLO servidor. Si queda vacío, el pago online se desactiva
# y el resto de métodos (efectivo, transferencia, etc.) siguen funcionando.
MERCADO_PAGO_ACCESS_TOKEN=
# Opcional: secreto para validar la firma del webhook (x-signature).
MERCADO_PAGO_WEBHOOK_SECRET=

# --- Panel de administración (/admin) ---------------------------------
# Contraseña para entrar al panel del negocio.
ADMIN_PASSWORD=cambiar-esta-clave
# Secreto para firmar la cookie de sesión del admin (texto largo aleatorio).
ADMIN_SESSION_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# --- Legacy / respaldo ------------------------------------------------
# Menú desde Google Sheets (CSV). Solo se usa si NO hay Supabase configurado.
NEXT_PUBLIC_MENU_CSV_URL=
