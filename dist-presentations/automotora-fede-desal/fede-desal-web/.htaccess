# =============================================================================
# Automotora Fede Desal — .htaccess (Hostinger / Apache)
# Evita que el servidor sirva versiones viejas de HTML/CSS/JS tras actualizar.
# =============================================================================

# --- Cache-Control -----------------------------------------------------------
<IfModule mod_headers.c>
  # HTML / CSS / JS / JSON: validar siempre (que se vean los cambios al subir)
  <FilesMatch "\.(html|css|js|mjs|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Imágenes y fuentes: cachear 1 mes (cambian poco)
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# --- Compresión gzip ---------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# --- Página de inicio --------------------------------------------------------
DirectoryIndex index.html

# --- 404 → al inicio (opcional) ----------------------------------------------
ErrorDocument 404 /index.html

# --- Seguridad mínima --------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
</IfModule>
Options -Indexes
